# ---- Rust ----
# Build artifacts (Cargo's output directory, per-module)
target/

# rustfmt backup files
**/*.rs.bk

# Debug symbols on Windows / cross-compile
*.pdb

# Cargo.lock policy:
#   - Commit it for binary crates (the modules here are CLIs, so commit).
#   - Ignore it for library crates.
# Not ignored on purpose.

# ---- C ----
# Object files and precompiled headers
*.o
*.ko
*.obj
*.elf
*.gch
*.pch

# Static and shared libraries
*.a
*.la
*.lib
*.so
*.so.*
*.dylib
*.dll

# Linker output / executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug + coverage
*.dSYM/
*.su
*.idb
*.pdb
*.gcno
*.gcda
*.gcov

# Make / autotools dependency files
*.d
*.mod

# Common executable names from 42 / crackme work — uncomment if needed
# reverse_me
# a.out

# ---- Editors / OS ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.DS_Store

# ---- Project-local outputs ----
# Arachnida default output dir (-p ./data/)
data/
# Stockholm / iron_dome / etc. — add per-module output paths as they appear

# ---- Repo policy ----
docs/
notes/
CLAUDE.md
AGENTS.md
